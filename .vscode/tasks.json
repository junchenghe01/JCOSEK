{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run QEMU Server",
            "type": "shell",
            "command": "pkill -9 qemu-system-arm || true; qemu-system-arm -M vexpress-a9 -m 512M -kernel ${workspaceFolder}/build/JCOSEK.elf -nographic -s -S",
            "isBackground": true,
            "problemMatcher": {
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "dependsOn": "Build RTOS"
        },
        {
            "label": "Build RTOS",
            "type": "shell",
            "command": "cd ${workspaceFolder}/build && rm -rf * && cmake -DSYS_TEST=test_05_ISR .. && cmake --build .",
            "problemMatcher": []
        },
        {
            "label": "Build doc",
            "type": "shell",
            "command": "cd ${workspaceFolder}/build && rm -rf * && cmake -DSYS_TEST=test_05_ISR .. && cmake --build . --target doc",
            "problemMatcher": []
        }
    ]
}